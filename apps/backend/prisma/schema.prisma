generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id      String  @id @default(uuid())
  name    String
  address String?

  createdAt DateTime @default(now())

  devices Device[]
}

model User {
  id String @id @default(uuid())

  name         String
  email        String @unique
  passwordHash String

  role String @default("employee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id String @id @default(uuid())

  fullName String
  phone    String @unique

  createdAt DateTime @default(now())
}

model Device {
  id String @id @default(uuid())

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  imei String @unique

  brand String
  model String

  storage String?
  color   String?

  batteryHealth Int?

  purchasePrice Float
  salePrice     Float

  status String

  createdAt DateTime @default(now())

  sales Sale[]
}

model Sale {
  id String @id @default(uuid())

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  salePrice Float

  createdAt DateTime @default(now())
}
